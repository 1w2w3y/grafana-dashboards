        "wideLayout": true
      },
      "pluginVersion": "11.6.9",
      "targets": [
        {
          "azureLogAnalytics": {
            "dashboardTime": true,
            "query": "let llm = dependencies\n| where cloud_RoleName == \"openclaw-gateway\"\n| where name == \"openclaw.model.usage\"\n| extend\n    output_tokens = tolong(customDimensions[\"openclaw.tokens.output\"]),\n    cache_read = tolong(customDimensions[\"openclaw.tokens.cache_read\"])\n| summarize\n    ['LLM Calls'] = count(),\n    ['Output Tokens'] = sum(output_tokens),\n    ['Cache Read Tokens'] = sum(cache_read),\n    ['Avg LLM Time (s)'] = round(avg(duration) / 1000, 1);\nlet stuck = dependencies\n| where cloud_RoleName == \"openclaw-gateway\"\n| where name == \"openclaw.session.stuck\"\n| summarize ['Stuck Sessions'] = dcount(tostring(customDimensions[\"openclaw.sessionKey\"]));\nllm | extend dummy = 1\n| join kind=inner (stuck | extend dummy = 1) on dummy\n| project ['LLM Calls'], ['Output Tokens'], ['Cache Read Tokens'], ['Avg LLM Time (s)'], ['Stuck Sessions']",
            "resources": [
              "/subscriptions/$sub/resourceGroups/$rg/providers/microsoft.insights/components/$res"
            ],
            "resultFormat": "time_series",
            "timeColumn": "timestamp"
          },
          "datasource": {
            "type": "grafana-azure-monitor-datasource",
            "uid": "${DS_AZURE_MONITOR}"
          },
          "queryType": "Azure Log Analytics",
          "refId": "A"
        }
      ],
      "title": "LLM & Health Summary",
      "type": "stat"
    },
